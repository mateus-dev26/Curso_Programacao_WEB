algoritmo "o suco"

var
    suco_1, suco_2, suco_3: caracter

inicio
    suco_1 <- "Laranja"
    suco_2 <- "Maracujá"
    suco_3 <- "X"

    escreval("Carina gosta de: ", suco_1, " tem 11 anos.")
    escreval("Talita gosta de: ", suco_3, " tem 9 anos.")
    escreval("Lucas gosta de: ", suco_2, " tem 8 anos.")


fimalgoritmo