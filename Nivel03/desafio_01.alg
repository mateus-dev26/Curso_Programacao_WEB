algoritmo "Catraca de laboratorio"

var
    idade: inteiro
    
inicio
    escreva("Digite sua idade: ")
    leia(idade)
    se (idade >= 18) entao
        escreval ("Acesso Liberado: Máquina habilitada")
    senao
        escreval ("Acesso Negado: Risco de Segurança. Procure o professor.")
    fimse

fimalgoritmo