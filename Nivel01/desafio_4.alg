algoritmo "Nome do Programa"

var
    item: caracter
    
inicio
    escreva("Digite o nome do primeiro item: ")
    leia(item)
    escreval("Item 1 registrado é: ", item)
    escreva("Digite o nome do próximo item: ")
    leia(item)
    escreval("Item 1 descartado.Item 2 registrado é: ", item)
    item <-- ""
    escreval("Inventário resetado. Valor atual: ", item)


fimalgoritmo