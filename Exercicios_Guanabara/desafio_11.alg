algoritmo "Delta"

var
    a, b, c, delta: real

inicio
    escreva("Digite o valor de A: ")
    leia(a)
    escreva("Digite o valor de B: ")
    leia(b)
    escreva("Digite o valor de C: ")
    leia(c)

    delta := (b * b) - (4 * a * c)

    escreval("O valor do Delta é: ", delta)


fimalgoritmo