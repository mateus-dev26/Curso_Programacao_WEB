algoritmo "Funcionario"

var
nome: caractere
salario: real

inicio
    escreva("Digite o nome do funcionário: ")
    leia(nome)
    escreva("Digite o salário do funcionário: ")
    leia(salario)
    escreva("O funcionário ", nome, " tem um salário de R$ ", salario:0:2, " em Junho.")

fimalgoritmo